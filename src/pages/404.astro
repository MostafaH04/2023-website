---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — Mostafa Hussein"
  description="The requested page could not be found. Return to Mostafa Hussein's portfolio or browse the projects."
  noindex
>
  <main class="page-main page-shell not-found" id="main-content" tabindex="-1">
    <div>
      <p class="not-found__code" aria-hidden="true">404</p>
      <p class="eyebrow">Off the map</p>
      <h1 class="section-title">This route doesn&rsquo;t lead anywhere.</h1>
      <p class="lead">
        The page may have moved, but the projects are still ready to explore.
      </p>
      <div class="button-row button-row--center">
        <a class="button button--primary" href="/">Go home</a>
        <a class="button button--secondary" href="/projects">View projects</a>
      </div>
    </div>
  </main>
</BaseLayout>
